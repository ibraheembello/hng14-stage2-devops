# ----------------------------------------------------------------------
# .env.example — placeholder values for every variable the stack needs.
# Copy this file to .env before running `docker compose up`:
#     cp .env.example .env
# Then edit .env and replace placeholders with real values.
# NEVER commit the real .env to git.
# ----------------------------------------------------------------------

# ---- Redis ----
# Hostname the api and worker use to reach Redis. Inside docker-compose
# this is the service name, "redis". Override for other environments.
REDIS_HOST=redis
REDIS_PORT=6379
# Must be a strong password in any non-local environment.
REDIS_PASSWORD=changeme_use_a_strong_password

# ---- API (FastAPI) ----
API_PORT=8000
APP_ENV=production
# uvicorn log level: debug | info | warning | error | critical
API_LOG_LEVEL=info

# ---- Frontend (Node/Express) ----
FRONTEND_PORT=3000
# Hostname:port the frontend uses to reach the API. Inside docker-compose
# this is the api service name.
API_URL=http://api:8000

# ---- Worker ----
# How often (seconds) the worker writes a heartbeat key to Redis so
# its healthcheck can verify it is alive.
WORKER_HEARTBEAT_INTERVAL=10
